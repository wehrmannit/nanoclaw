# MemOS Configuration
TZ=UTC

# Chat LLM — uses Ollama (local, no API key needed)
MOS_CHAT_MODEL=qwen3.5:0.8b
MOS_CHAT_MODEL_PROVIDER=openai
MOS_CHAT_TEMPERATURE=0.7
MOS_MAX_TOKENS=2048
MOS_TOP_P=0.9
OPENAI_API_KEY=ollama
OPENAI_API_BASE=http://ollama:11434/v1

# MemReader / retrieval LLM (also Ollama)
MEMRADER_MODEL=qwen3.5:0.8b
MEMRADER_API_KEY=ollama
MEMRADER_API_BASE=http://ollama:11434/v1
MEMRADER_MAX_TOKENS=2048

# Embeddings — Ollama with nomic-embed-text
EMBEDDING_DIMENSION=768
MOS_EMBEDDER_BACKEND=ollama
MOS_EMBEDDER_MODEL=nomic-embed-text
OLLAMA_API_BASE=http://ollama:11434

# Reranker — use cosine similarity (no external service needed)
MOS_RERANKER_BACKEND=cosine_local

# Memory settings
MOS_TEXT_MEM_TYPE=general_text
MOS_ENABLE_DEFAULT_CUBE_CONFIG=true
MOS_ENABLE_REORGANIZE=false
ENABLE_PREFERENCE_MEMORY=false
ENABLE_INTERNET=false

# Neo4j (overridden by docker-compose, but needed for env file)
NEO4J_BACKEND=neo4j-community
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=memos_secure_2026
NEO4J_DB_NAME=neo4j
MOS_NEO4J_SHARED_DB=false

# Qdrant (overridden by docker-compose)
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Reader chunking
MEM_READER_BACKEND=simple_struct
MEM_READER_CHAT_CHUNK_TYPE=default
MEM_READER_CHAT_CHUNK_TOKEN_SIZE=1600
MEM_READER_CHAT_CHUNK_SESS_SIZE=10
MEM_READER_CHAT_CHUNK_OVERLAP=2

# Scheduler (disabled — we handle orchestration ourselves)
MOS_ENABLE_SCHEDULER=false
API_SCHEDULER_ON=false

# Search
SEARCH_MODE=fast
MOS_TOP_K=20
